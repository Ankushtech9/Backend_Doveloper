<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>RuralDoc AI | Professional</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    :root {
      --primary: #10b981;
      --primary-dark: #065f46;
      --bg-glass: rgba(255, 255, 255, 0.7);
      --bg-main: #f5f5f7;
      --text-main: #1d1d1f;
      --text-muted: #86868b;
      --card-shadow: 0 8px 30px rgba(0,0,0,0.04);
      --radius-apple: 28px;
      --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-font-smoothing: antialiased; }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background-color: var(--bg-main);
      color: var(--text-main);
      display: flex;
      height: 100vh;
      overflow: hidden;
      letter-spacing: -0.022em;
    }

    /* --- SIDEBAR --- */
    .sidebar {
      width: 280px;
      background: white;
      padding: 40px 24px;
      display: flex;
      flex-direction: column;
      border-right: 1px solid rgba(0,0,0,0.05);
      z-index: 10;
    }

    .logo {
      font-weight: 800;
      font-size: 22px;
      color: var(--text-main);
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 50px;
      padding-left: 12px;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 18px;
      color: var(--text-muted);
      font-weight: 500;
      border-radius: 16px;
      cursor: pointer;
      margin-bottom: 6px;
      transition: var(--transition);
    }
.nav-item:hover { background: #f2f2f7; color: var(--text-main); }
    .nav-item.active { background: var(--text-main); color: white; box-shadow: 0 10px 20px rgba(0,0,0,0.1); }

    /* --- MAIN AREA --- */
    .main-content {
      flex: 1;
      overflow-y: auto;
      padding: 50px 80px;
      scroll-behavior: smooth;
    }

    .page { display: none; opacity: 0; transform: translateY(20px); }
    .page.active { display: block; opacity: 1; transform: translateY(0); transition: var(--transition); }

    /* --- BENTO HOME --- */
    .hero-section {
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      border-radius: var(--radius-apple);
      padding: 60px;
      color: white;
      position: relative;
      margin-bottom: 30px;
      box-shadow: 0 20px 40px rgba(16, 185, 129, 0.2);
    }

    .hero-section h1 { font-size: 48px; font-weight: 700; margin-bottom: 16px; }
    .hero-section p { font-size: 18px; opacity: 0.9; max-width: 500px; margin-bottom: 30px; }

    .bento-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 24px;
    }

