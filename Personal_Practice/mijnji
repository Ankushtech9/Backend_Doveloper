<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>RuralDoc AI | Professional</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    :root {
      --primary: #10b981;
      --primary-dark: #065f46;
      --bg-glass: rgba(255, 255, 255, 0.7);
      --bg-main: #f5f5f7;
      --text-main: #1d1d1f;
      --text-muted: #86868b;
      --card-shadow: 0 8px 30px rgba(0,0,0,0.04);
      --radius-apple: 28px;
      --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-font-smoothing: antialiased; }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background-color: var(--bg-main);
      color: var(--text-main);
      display: flex;
      height: 100vh;
      overflow: hidden;
      letter-spacing: -0.022em;
    }

    /* --- SIDEBAR --- */
    .sidebar {
      width: 280px;
      background: white;
      padding: 40px 24px;
      display: flex;
      flex-direction: column;
      border-right: 1px solid rgba(0,0,0,0.05);
      z-index: 10;
    }

    .logo {
      font-weight: 800;
      font-size: 22px;
      color: var(--text-main);
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 50px;
      padding-left: 12px;
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 18px;
      color: var(--text-muted);
      font-weight: 500;
      border-radius: 16px;
      cursor: pointer;
      margin-bottom: 6px;
      transition: var(--transition);
    }
.nav-item:hover { background: #f2f2f7; color: var(--text-main); }
    .nav-item.active { background: var(--text-main); color: white; box-shadow: 0 10px 20px rgba(0,0,0,0.1); }

    /* --- MAIN AREA --- */
    .main-content {
      flex: 1;
      overflow-y: auto;
      padding: 50px 80px;
      scroll-behavior: smooth;
    }

    .page { display: none; opacity: 0; transform: translateY(20px); }
    .page.active { display: block; opacity: 1; transform: translateY(0); transition: var(--transition); }

    /* --- BENTO HOME --- */
    .hero-section {
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      border-radius: var(--radius-apple);
      padding: 60px;
      color: white;
      position: relative;
      margin-bottom: 30px;
      box-shadow: 0 20px 40px rgba(16, 185, 129, 0.2);
    }

    .hero-section h1 { font-size: 48px; font-weight: 700; margin-bottom: 16px; }
    .hero-section p { font-size: 18px; opacity: 0.9; max-width: 500px; margin-bottom: 30px; }

    .bento-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 24px;
    }

    .bento-card {
      background: white;
      border-radius: var(--radius-apple);
      padding: 30px;
      box-shadow: var(--card-shadow);
      transition: var(--transitio
 }

    .bento-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(0,0,0,0.08); }

    /* --- FORMS --- */
    .glass-card {
      background: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(20px);
      border-radius: var(--radius-apple);
      padding: 40px;
      max-width: 800px;
      margin: 0 auto;
      border: 1px solid rgba(255, 255, 255, 0.5);
      box-shadow: var(--card-shadow);
    }

    .input-wrapper {
      background: #f2f2f7;
      border-radius: 18px;
      margin-bottom: 20px;
      padding: 12px 20px;
      border: 2px solid transparent;
      transition: var(--transition);
    }

    .input-wrapper:focus-within {
      background: white;
      border-color: var(--primary);
    }

    label { font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; margin-bottom: 6px; display: block; }

    textarea, input, select {
      width: 100%; border: none; background: transparent; font-family: inherit; font-size: 16px; outline: none; color: var(--text-main);
    }

    .btn-apple {
      background: var(--text-main); color: white; padding: 18px 32px; border-radius: 50px; border: none; font-weight: 600; cursor: pointer; transition: var(--transition);
      display: flex; align-items: center; justify-content: center; gap: 10px; width: 100%;
    }

    .btn-apple:hover { transform: scale(1.02); background: #000; }

    /* --- RESULTS & BADGES --- */
    .urgency-badge { padding: 6px 16px; border-radius: 50px; font-weight: 700; font-size: 12px; }
    .urgency-LOW { background: #dcfce7; color: #166534; }
    .urgency-MEDIUM { background: #fef9c3; color: #854d0e; }
    .urgency-HIGH { background: #fee2e2; color: #991b1b; }

    .issue-row {
      display: flex; align-items: center; gap: 20px; background: white; padding: 20px; border-radius: 20px; margin-bottom: 12px;
    }

    /* --- LIBRARY --- */
    .library-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
        margin-top: 30px;
    }
    .library-card {
        background: white; padding: 25px; border-radius: 24px; border: 1px solid #eee;
    }
    .tag {
        font-size: 10px; background: #f2f2f7; padding: 4px 8px; border-radius: 4px; font-weight: bold; margin-bottom: 10px; display: inline-block;
    }

    /* --- SPINNER --- */
    .spinner {
      width: 40px; height: 40px; border: 4px solid #f3f3f3; border-top: 4px solid var(--primary);
      border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 20px;
    }
    @keyframes spin { 100% { transform: rotate(360deg); } }
  </style>
</head>
<body>

